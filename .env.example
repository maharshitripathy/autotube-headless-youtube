# ---------- Core ----------
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
# Fernet key for encrypting OAuth tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Single-user local auth (P0 recommendation)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ---------- Datastores ----------
DATABASE_URL=postgresql+psycopg://autotube:autotube@postgres:5432/autotube
REDIS_URL=redis://redis:6379/0

# ---------- Object storage (MinIO / S3) ----------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=autotube-media
S3_REGION=us-east-1

# ---------- AI providers ----------
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=

# Google Veo 3 (optional hero clips via Vertex AI)
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-service-account.json
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VEO_ENABLED=false

# Local captions
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# ---------- YouTube OAuth ----------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback

# Web app URL (post-OAuth redirect target)
WEB_APP_URL=http://localhost:5173

# ---------- Cost guardrails (P0 recommendation) ----------
# Hard caps enforced before any paid API call. Set 0 to disable a cap.
COST_CAP_PER_VIDEO_USD=2.00
COST_CAP_PER_CHANNEL_DAILY_USD=10.00
COST_CAP_GLOBAL_DAILY_USD=50.00
