FROM node:20-bookworm-slim

# Chromium/ffmpeg deps for Remotion headless rendering
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libnss3 libdbus-1-3 libatk1.0-0 libgbm1 libasound2 \
    libatk-bridge2.0-0 libcups2 libxkbcommon0 libxcomposite1 \
    libxdamage1 libxfixes3 libxrandr2 libpango-1.0-0 libcairo2 \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

EXPOSE 3001

CMD ["npm", "run", "serve"]
